# Upstream: https://aur.archlinux.org/libreelec-dvb-firmware-git.git

source PKGBUILD
unset epoch

pkgver=1.5.0.r1.g90261ae
pkgrel=1
license=('LicenseRef-Redistributable')  # SPDX
# Account for post linux-firmware package split
makedepends+=(linux-firmware-{liquidio,marvell,mellanox,nfp,qcom,qlogic})

eval orig_"$(declare -f package)"
package() {
    orig_package

    install -d "${pkgdir}/usr/share/licenses/${pkgname}"
    mv -f "${pkgdir}/usr/lib/firmware/dvb-usb-SkyStar_USB_HD_FW_v17_63.HEX.fw.license.txt" \
        "${pkgdir}/usr/share/licenses/${pkgname}/"
}
