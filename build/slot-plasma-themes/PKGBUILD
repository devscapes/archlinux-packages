package_slot-icon-theme() {
    pkgdesc+=' - icon themes'
    depends=(
        breeze-icons
        hicolor-icon-theme
    )
    optdepends=('slot-icon-theme-extra: additional icon theme variants')

    pushd "${pkgbase}-${pkgver}/Slot Icons Themes"
    _install_icons Slot-Dark-Icons
    _install_icons Slot-Light-Icons
    popd
}

package_slot-icon-theme-extra() {
    pkgdesc+=' - extra icon themes (Blue, Color, Multicolor)'
    depends=(
        adwaita-icon-theme  # for Color variants
        breeze-icons
    )

    pushd "${pkgbase}-${pkgver}/Slot Icons Themes"
    _install_icons Slot-Blue-Dark-Icons Slot-Dark-Icons
    _install_icons Slot-Color-Dark-Icons Slot-Dark-Icons
    _install_icons Slot-Multicolor-Dark-Icons Slot-Dark-Icons
    _install_icons Slot-Blue-Light-Icons Slot-Light-Icons
    _install_icons Slot-Color-Light-Icons Slot-Light-Icons
    _install_icons Slot-Multicolor-Light-Icons Slot-Light-Icons
    popd
}

