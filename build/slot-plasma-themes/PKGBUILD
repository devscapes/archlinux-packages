package_metacity-theme-slot-spectrum-dark() {
    pkgdesc+=' - Spectrum GNOME Flashback dark theme'
    depends=(
        gtk-theme-slot-spectrum-dark
        metacity
    )

    pushd "${pkgbase}-${pkgver}/Slot GTK Themes"
    install -d "${pkgdir}/usr/share/themes/Slot-Spectrum-Dark-GTK"
    cp -r -v --no-preserve=all Slot-Spectrum-Dark-GTK/metacity-1 \
        "${pkgdir}/usr/share/themes/Slot-Spectrum-Dark-GTK"
    popd
}

package_plasma6-themes-slot-dark() {
    pkgdesc+=' - dark theme'
    depends=(
        kwin
        plasma-desktop
    )
    optdepends=(
        'gtk-theme-slot-dark: for matching GTK+ theme'
        'kvantum-theme-slot-dark: for matching Kvantum theme'
        'sddm-theme-slot: for matching SDDM theme'
        'slot-icon-theme: for matching icon theme'
    )

    cd "${pkgbase}-${pkgver}"

    pushd 'Slot Window Decorations'
    install -d "${pkgdir}/usr/share/aurorae/themes"
    cp -r -v --no-preserve=all -t "${pkgdir}/usr/share/aurorae/themes" Slot-{Blur-,}Dark-Aurorae-6
    popd

    pushd 'Slot Color Schemes'
    install -d "${pkgdir}/usr/share/color-schemes"
    cp -r -v --no-preserve=all SlotDarkColorscheme.colors "${pkgdir}/usr/share/color-schemes"
    popd

    pushd 'Slot Plasma Themes'
    install -d "${pkgdir}/usr/share/plasma/desktoptheme"
    cp -r -v --no-preserve=all Slot-Dark-Plasma "${pkgdir}/usr/share/plasma/desktoptheme"
    rm -f "${pkgdir}/usr/share/plasma/desktoptheme/Slot-Dark-Plasma/metadata.desktop"
    popd

    pushd 'Slot Global Themes'
    install -d "${pkgdir}/usr/share/plasma/look-and-feel"
    cp -r -v --no-preserve=all Slot-Dark-Global-6 "${pkgdir}/usr/share/plasma/look-and-feel"
    popd

    install -D -m 644 'Slot Wallpapers/Slot Wallpaper Without Plasma Logo.jpg' \
        "${pkgdir}/usr/share/wallpapers/Slot-Wallpapers/Slot Wallpaper.jpg"
}

package_plasma6-themes-slot-gradient-dark() {
    pkgdesc+=' - Gradient dark theme'
    depends=(
        plasma6-themes-slot-dark
        ars-wallpapers
        plasma6-aurorae-theme-gradient-dark
    )
    optdepends=(
        'gtk-theme-slot-dark: for matching GTK+ theme'
        'kvantum-theme-slot-dark: for matching Kvantum theme'
        'sddm-theme-slot: for matching SDDM theme'
        'slot-gradient-icon-theme: for matching icon theme'
    )

    pushd "${pkgbase}-${pkgver}/Slot Global Themes"
    install -d "${pkgdir}/usr/share/plasma/look-and-feel"
    cp -r -v --no-preserve=all Slot-Gradient-Dark-Global-6 \
        "${pkgdir}/usr/share/plasma/look-and-feel"
    popd
}

package_plasma6-themes-slot-spectrum() {
    pkgdesc+=' - Spectrum themes'
    depends=(plasma6-themes-dream)  # for aurorae, desktoptheme, and wallpapers
    optdepends=(
        'gtk-theme-slot-spectrum-dark: for matching GTK+ theme (Dark only)'
        'kvantum-theme-slot-spectrum-dark: for matching Kvantum theme (Dark only)'
        'sddm-theme-slot: for matching SDDM theme (shared)'
        'slot-spectrum-icon-theme: for matching icon theme (Dark/Light)'
    )

    cd "${pkgbase}-${pkgver}"

    pushd 'Slot Color Schemes'
    install -d "${pkgdir}/usr/share/color-schemes"
    cp -r -v --no-preserve=all -t "${pkgdir}/usr/share/color-schemes" \
        Spectrum{Dark,Light}Color.colors
    popd

    pushd 'Slot Global Themes'
    install -d "${pkgdir}/usr/share/plasma/look-and-feel"
    cp -r -v --no-preserve=all -t "${pkgdir}/usr/share/plasma/look-and-feel" \
        Slot-Spectrum-{Dark,Light}-Global-6
    popd
}

package_sddm-theme-slot() {
    pkgdesc+=' - SDDM theme'
    depends=(sddm)

    pushd "${pkgbase}-${pkgver}/Slot SDDM Themes"
    install -d "${pkgdir}/usr/share/sddm/themes"
    cp -r -v --no-preserve=all Slot-SDDM-6 "${pkgdir}/usr/share/sddm/themes"
    popd
