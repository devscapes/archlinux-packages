pkgbase=slot-plasma-themes
pkgname=(
    gtk-theme-slot-dark
    gtk-theme-slot-spectrum-dark
    kvantum-theme-slot-dark
    kvantum-theme-slot-spectrum-dark
    metacity-theme-slot-spectrum-dark
    plasma6-themes-slot-dark
    plasma6-themes-slot-gradient-dark
    plasma6-themes-slot-spectrum
    sddm-theme-slot
    slot-icon-theme
    slot-icon-theme-extra              # any other variants not specified below
    slot-gradient-icon-theme
    slot-spectrum-icon-theme
    slot-symbolic-icon-theme           # optional for dream-plasma-themes
)
pkgver=5.0_20251009
pkgrel=2
epoch=1
pkgdesc='Slot themes for Plasma desktop'
arch=(any)
url='https://github.com/L4ki/Slot-Plasma-Themes'
license=(GPL-3.0-only)
# We need these to tone down icon themes size a bit
makedepends=(
    rdfind
    symlinks
)
options=(!strip !emptydirs)
_commit=c55b3b3c33421dd2f9aefa3b84531666511adebe
source=("${pkgbase}-${pkgver}.tar.gz::${url}/archive/${_commit}.tar.gz")
noextract=("${pkgbase}-${pkgver}.tar.gz")
sha384sums=('e3a35143cf4bee2fb4dd5db4898c8d7164b3a0c30081fbc85a78660bd297da71f0b9bfbfd544bc66af947a7a32b913e0')
b2sums=('a31724a62fd8eb47b26b61a7fec967529fabf100f28bcbd89e23f7d4ed1ef4b6cc4862032d9a2fc799c350aaafae065b80780b5b7d5eb4cd6665a9647f410a46')

_install_icons() {
    local _base _iconsdir _path _theme
    _iconsdir=${pkgdir}/usr/share/icons
    _theme=$1
    _base=$2

    install -d "${_iconsdir}"
    echo "Installing ${_theme} theme..."
    cp -r -v --no-preserve=all "${_base:-${_theme}}" "${_iconsdir}/${_theme}"
    [[ -n ${_base} ]] && cp -f -r -v --no-preserve=all "${_theme}/"* "${_iconsdir}/${_theme}/"
    rdfind -checksum sha512 -makesymlinks true -makeresultsfile false "${_iconsdir}/${_theme}"
    symlinks -c -r "${_iconsdir}/${_theme}"
}

prepare() {
    mkdir ${pkgbase}-${pkgver}
    tar xf ${pkgbase}-${pkgver}.tar.gz -C ${pkgbase}-${pkgver} --strip-components 1
    cd "${srcdir}/${pkgbase}-${pkgver}"

    # Remove junk files
    find . \( -name 32.files -o -name 48.files -o -name 'Text File.txt' -o -name icon-theme.cache \
        -o -name make-symlinks.sh \) -delete
    rm -f 'Slot Plasma Themes/Slot-Dark-Plasma/'{AUTHORS,LICENSE}

    cd "${srcdir}/${pkgbase}-${pkgver}/Slot Icons Themes"

    # Symlink any @2x, @3x, ... to their original non-scaled icons
    find . -type f \( -name 16 -o -name 22 -o -name 24 \) | while IFS= read -r _fixup; do
        rm -r "$(dirname "${_fixup}")"
        ln -s "$(basename "${_fixup}")" "$(dirname "${_fixup}")"
    done

    # Get rid of any incorrect files present on icon themes
    find . -type f ! \( -iname '*.svg' -o -name index.theme \) -delete

    # Move some icons to their proper place
    mkdir Slot-Blue-Light-Icons/places
    mv -t Slot-Blue-Light-Icons/places Slot-Blue-Light-Icons/{32,64}
    mv Slot-Light-Icons/*.svg Slot-Light-Icons/mimetypes/64

    # Fix fallback icons for some themes
    sed 's/breeze,/breeze-dark,/' -i Slot-{Blue,Multicolor,Symbolic}-Dark-Icons/index.theme

    # Breeze Dark implies Breeze for its fallback, no need to specify again
    sed 's/breeze,//' -i Slot-{,Gradient-}Dark-Icons/index.theme

    # Why would light variant want Adwaita fallback when dark isn't?
    sed 's/Adwaita,//' -i Slot-Light-Icons/index.theme
}

package_gtk-theme-slot-dark() {
    pkgdesc+=' - GTK+ dark theme'
    depends=(gtk{3,4})
    optdepends=(
        'breeze-icons: default cursor theme when using on GTK+ desktop'
        'gtk-engine-murrine: for using GTK2 theme'
        'xcursor-breeze: default cursor theme when using on GTK+ desktop'
    )

    pushd "${pkgbase}-${pkgver}/Slot GTK Themes"
    install -d "${pkgdir}/usr/share/themes"
    cp -r -v --no-preserve=all Slot-Dark-GTK "${pkgdir}/usr/share/themes"
    popd
}

package_gtk-theme-slot-spectrum-dark() {
    pkgdesc+=' - Spectrum GTK+ dark theme'
    depends=(gtk{3,4})
    optdepends=(
        'gtk-engine-murrine: for using GTK2 theme'
        'xcursor-dmz: default cursor theme when using on GTK+ desktop'
    )

    pushd "${pkgbase}-${pkgver}/Slot GTK Themes"
    install -d "${pkgdir}/usr/share/themes"
    cp -r -v --no-preserve=all Slot-Spectrum-Dark-GTK "${pkgdir}/usr/share/themes"
    # Split metacity theme to a separate package that will depend on this split package
    rm -r "${pkgdir}/usr/share/themes/Slot-Spectrum-Dark-GTK/metacity-1"
    popd
}

