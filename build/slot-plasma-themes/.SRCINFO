pkgname = gtk-theme-slot-dark
	pkgdesc = Slot themes for Plasma desktop - GTK+ dark theme
	depends = gtk3
	depends = gtk4
	optdepends = breeze-icons: default cursor theme when using on GTK+ desktop
	optdepends = gtk-engine-murrine: for using GTK2 theme
	optdepends = xcursor-breeze: default cursor theme when using on GTK+ desktop

pkgname = gtk-theme-slot-spectrum-dark
	pkgdesc = Slot themes for Plasma desktop - Spectrum GTK+ dark theme
	depends = gtk3
	depends = gtk4
	optdepends = gtk-engine-murrine: for using GTK2 theme
	optdepends = xcursor-dmz: default cursor theme when using on GTK+ desktop

pkgname = kvantum-theme-slot-dark
	pkgdesc = Slot themes for Plasma desktop - Kvantum dark theme
	depends = kvantum

pkgname = kvantum-theme-slot-spectrum-dark
	pkgdesc = Slot themes for Plasma desktop - Spectrum Kvantum dark theme
	depends = kvantum

pkgname = metacity-theme-slot-spectrum-dark
	pkgdesc = Slot themes for Plasma desktop - Spectrum GNOME Flashback dark theme
	depends = gtk-theme-slot-spectrum-dark
	depends = metacity

pkgname = plasma6-themes-slot-dark
	pkgdesc = Slot themes for Plasma desktop - dark theme
	depends = kwin
	depends = plasma-desktop
	optdepends = gtk-theme-slot-dark: for matching GTK+ theme
	optdepends = kvantum-theme-slot-dark: for matching Kvantum theme
	optdepends = sddm-theme-slot: for matching SDDM theme
	optdepends = slot-icon-theme: for matching icon theme

pkgname = plasma6-themes-slot-gradient-dark
	pkgdesc = Slot themes for Plasma desktop - Gradient dark theme
	depends = plasma6-themes-slot-dark
	depends = ars-wallpapers
	depends = plasma6-aurorae-theme-gradient-dark
	optdepends = gtk-theme-slot-dark: for matching GTK+ theme
	optdepends = kvantum-theme-slot-dark: for matching Kvantum theme
	optdepends = sddm-theme-slot: for matching SDDM theme
	optdepends = slot-gradient-icon-theme: for matching icon theme

pkgname = plasma6-themes-slot-spectrum
	pkgdesc = Slot themes for Plasma desktop - Spectrum themes
	depends = plasma6-themes-dream
	optdepends = gtk-theme-slot-spectrum-dark: for matching GTK+ theme (Dark only)
	optdepends = kvantum-theme-slot-spectrum-dark: for matching Kvantum theme (Dark only)
	optdepends = sddm-theme-slot: for matching SDDM theme (shared)
	optdepends = slot-spectrum-icon-theme: for matching icon theme (Dark/Light)

pkgname = sddm-theme-slot
	pkgdesc = Slot themes for Plasma desktop - SDDM theme
	depends = sddm

pkgname = slot-icon-theme
	pkgdesc = Slot themes for Plasma desktop - icon themes
	depends = breeze-icons
	depends = hicolor-icon-theme
	optdepends = slot-icon-theme-extra: additional icon theme variants

pkgname = slot-icon-theme-extra
	pkgdesc = Slot themes for Plasma desktop - extra icon themes (Blue, Color, Multicolor)
	depends = adwaita-icon-theme
	depends = breeze-icons

pkgname = slot-gradient-icon-theme
	pkgdesc = Slot themes for Plasma desktop - Gradient icon themes
	depends = adwaita-icon-theme
	depends = breeze-icons

pkgname = slot-spectrum-icon-theme
	pkgdesc = Slot themes for Plasma desktop - Spectrum icon themes
	depends = adwaita-icon-theme
	depends = breeze-icons

pkgname = slot-symbolic-icon-theme
	pkgdesc = Slot themes for Plasma desktop - Symbolic icon themes
	depends = breeze-icons
	depends = hicolor-icon-theme
