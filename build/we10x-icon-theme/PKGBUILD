pkgname=we10x-icon-theme
pkgver=20250827
pkgrel=1
pkgdesc='A colorful design icon theme for Linux desktop'
arch=(any)
url='https://store.kde.org/p/1366371'
license=(GPL-3.0-only)  # CHECKME
groups=(we10xos-theme)
makedepends=(git)
options=(!strip)
_commit=46487020da48ff8da702a2597b7b76143cffd9b0
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/yeyushengfan258/We10X-icon-theme/archive/${_commit}.tar.gz")
noextract=("${pkgname}-${pkgver}.tar.gz")
sha384sums=('718517ce2732ff5af5fa56b86a44eb056c7666fdcbe6d53e8a8fe5a8707a7f27f21403176032aeba17457201d53c03e2')
b2sums=('b9f0b5ee81ce42b4a414a7de88d5438485aef449024003117a97b188cdac3e289e677625201f1efbb8d9a4792eecb6f76452e433cdc9a09b455347d26326aff5')

prepare() {
    mkdir ${pkgname}-${pkgver}
    tar xf ${pkgname}-${pkgver}.tar.gz -C ${pkgname}-${pkgver} --strip-components 1
    cd ${pkgname}-${pkgver}

    # Don't trigger icon cache update when installing
    sed '/gtk-update-icon-cache/d' -i install.sh
}

package() {
    cd ${pkgname}-${pkgver}
    ./install.sh -d "${pkgdir}/usr/share/icons" -t all
    # This removes broken symlinks created by the script
    find "${pkgdir}/usr/share/icons" -type l \
        -exec sh -c 'for x; do [[ -e $x ]] || rm -v -f "$x"; done' _ {} +
}
