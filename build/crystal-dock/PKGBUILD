# Maintainer: SoftExpert <softexpert at gmail dot com>

pkgname=crystal-dock
pkgver=2.14+really2.15rc5
#pkgver=2.14
pkgrel=1
pkgdesc='A cool dock (desktop panel) for Linux desktop'
arch=(x86_64)
url='https://github.com/dangvd/crystal-dock'
license=(GPL-3.0-or-later)
depends=(
    gcc-libs
    glibc
    layer-shell-qt
    qt6-base
    wayland libwayland-client.so
)
makedepends=(
    extra-cmake-modules
    git
    vulkan-headers
)
_commit=586497cffcbd5d81a1045191fc09df5c069215cc  # Sets version to 2.15 RC5
source=("git+${url}.git#commit=${_commit}")
sha384sums=('e904d4729d1683fc37f57bd73be2ddafa85c503117626933253589fc658d6d1339ad4bc01610a696b8dc131be19c2208')
b2sums=('3a1c49848a3266d9f2dac16a397750e13c03afbd3cdf9ef413f3940c0e9675528f0e56db5ccc6384d2f3e3f854fe59b43467a05aa4bcca828cdd868664d86f1e')

prepare() {
    # Qt 6.10 no longer implicitly imports private modules
    sed '/find_package[(]Qt6/s/Gui /Gui GuiPrivate /' -i ${pkgname}/src/CMakeLists.txt
}

build() {
    cmake -B build -S ${pkgname}/src -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build
}

package() {
    DESTDIR="${pkgdir}" cmake --install build
}

