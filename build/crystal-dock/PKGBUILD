# Maintainer: SoftExpert <softexpert at gmail dot com>

pkgname=crystal-dock
#pkgver=2.14+really2.15rc5
pkgver=2.16
pkgrel=1
pkgdesc='A cool dock (desktop panel) for Linux desktop'
arch=(x86_64)
url='https://github.com/dangvd/crystal-dock'
license=(GPL-3.0-or-later)
depends=(
    gcc-libs
    glibc
    layer-shell-qt
    qt6-base
    wayland libwayland-client.so
)
makedepends=(
    extra-cmake-modules
    git
    vulkan-headers
)
_commit=7a34e96f3a0abb55bc842a266bd152f59bcdee14  # Sets version to 2.16
source=("git+${url}.git#commit=${_commit}")
sha384sums=('d6b488328cef4c738f6a3918773fb2a3ace147670c06eed87aaba8ca0fb4296e1648d75d31d630f1f2630995d44a65e0')
b2sums=('4ccddbfcef5d2a136c34523ce55b66c3f348510bbb2f587d21363a1b9205054d467ec9e076342a3bd39f9626d0384ed118452d81456bb1eb8d77a148f14de0d6')

build() {
    cmake -B build -S ${pkgname}/src -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build
}

check() {
    ctest --test-dir build
}

package() {
    DESTDIR="${pkgdir}" cmake --install build
}

