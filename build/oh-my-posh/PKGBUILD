# Maintainer: Albert I <kras@raphielgang.org>
# Contributor: Jan0660 <jan0660@tutanota.com>

pkgname=oh-my-posh
pkgver=29.7.0
pkgrel=1
pkgdesc='A prompt theme engine for any shell'
arch=(
    aarch64
    armv7h
    i686
    pentium4
    x86_64
)
url='https://ohmyposh.dev'
license=(MIT)
depends=(
    glibc
)
makedepends=(
    git
    go
)
source=("${pkgname}::git+https://github.com/JanDeDobbeleer/oh-my-posh.git#tag=v${pkgver}")
sha384sums=('748a955160d9f70cb36c6efcb0d276e469f2485685a331afb467547a81f73464e2fccc5fabb803b05c2fa767f9da86a1')
b2sums=('584ed8279149d89d5eb7cd309a8d4e99e91a78af43cf8f3a14e1176bb2f614f43197bb284ef6a791fa7ec28719b1c5a42a94022259afa510c2b880f7dce32812')

_gourl=github.com/jandedobbeleer/${pkgname}/src/build

prepare() {
    cd ${pkgname}/src
    GOFLAGS='-mod=readonly' go mod vendor -v

    # Helps with build reproducibility
    SOURCE_DATE_EPOCH=$(git log -1 --pretty=%ct)
    export SOURCE_DATE_EPOCH

    # Hardcode build version to $pkgver
    sed "/Version/s/= .*$/= \"${pkgver}\"/" -i build/version.go
}

build() {
    export CGO_CPPFLAGS="${CPPFLAGS}"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS}"
    export GOFLAGS='-buildmode=pie -trimpath -mod=vendor -modcacherw'


    cd ${pkgname}/src
    _godate=$(date -u -d "@${SOURCE_DATE_EPOCH}" +"%Y-%m-%dT%H:%M:%SZ")
    go build -v -o ${pkgname} -ldflags="-X ${_gourl}.Date=${_godate} -linkmode=external" .
}

package() {
    cd ${pkgname}
    install -Dm755 src/${pkgname} "${pkgdir}/usr/bin/${pkgname}"
    install -Dt "${pkgdir}/usr/share/${pkgname}/themes" -m644 themes/*.omp.*
    install -Dm644 COPYING "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
}
