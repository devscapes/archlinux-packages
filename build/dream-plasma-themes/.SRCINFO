pkgname = gtk-theme-dream-dark
	pkgdesc = Dream themes for Plasma desktop - GTK+ dark themes
	depends = gtk3
	depends = gtk4
	optdepends = gtk-engine-murrine: for using GTK2 theme
	optdepends = xcursor-dmz: default cursor theme when using on GTK+ desktop

pkgname = konsole-colorscheme-dream
	pkgdesc = Dream themes for Plasma desktop - Konsole color schemes
	depends = konsole

pkgname = kvantum-theme-dream-dark
	pkgdesc = Dream themes for Plasma desktop - Kvantum dark themes
	depends = kvantum

pkgname = plasma6-themes-dream
	depends = kwin
	depends = plasma-desktop
	optdepends = gtk-theme-dream-dark: for matching GTK+ themes (Dark only)
	optdepends = konsole-colorscheme-dream: for matching Konsole color schemes (Dark/Light)
	optdepends = kvantum-theme-dream-dark: for matching Kvantum themes (Dark only)
	optdepends = sddm-theme-dream: for matching SDDM themes (Dark/Light)
	optdepends = slot-symbolic-icon-theme: for matching icon themes (Dark/Light)

pkgname = sddm-theme-dream
	pkgdesc = Dream themes for Plasma desktop - SDDM themes
	depends = sddm
